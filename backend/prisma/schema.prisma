generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Question {
  id            String   @id @default(uuid())
  subject       String
  topic         String
  level         String
  question      String
  options       String[]
  correctAnswer String
  hint          String
  solution      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([subject])
  @@index([subject, level])
}
